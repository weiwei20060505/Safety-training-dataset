# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Environment variables
.env
.env.*

# Large datasets and serialized models
data/
models/
*.pkl
*.csv

# Local results and outputs - ignore cache and binary files, but allow logs and plots
results/**/*
!results/**/
results/**/*.pkl
results/**/cache/
!results/**/*.png
!results/**/*.txt
!results/**/*.log
!results/**/*.md


